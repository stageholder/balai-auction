# --- Domain database (Prisma) ---
# Local dev: the standalone Docker Postgres (Plan 2, host port 5434).
# Production: your hosted Supabase project's Postgres connection string.
DATABASE_URL="postgresql://auction:auction@localhost:5434/auction"

# --- Supabase Auth ---
# Local dev: values from `supabase start` (API URL + anon key).
# Production: your hosted Supabase project URL + keys.
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<local anon key from `supabase start`>"
# Server-only (never NEXT_PUBLIC). Used for privileged server operations.
SUPABASE_SERVICE_ROLE_KEY="<local service_role key from `supabase start`>"
